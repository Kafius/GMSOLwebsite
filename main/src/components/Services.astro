---
/**
 * SERVICES GRID (Dark Theme)
 * Transitions back to Onyx Depth.
 */
import { FileText, ClipboardCheck, Globe, Database } from '@lucide/astro';
import H2 from './headerfont/H2.astro';
import SectionLabel from './headerfont/SectionLabel.astro';



const services = [
  {
    title: "Music Cue Sheet Processing",
    Icon: FileText,
    id: "PRO-01"
  },
  {
    title: "Header Verification & Creation",
    Icon: ClipboardCheck,
    id: "PRO-02"
  },
  {
    title: "Common Works Registration",
    Icon: Globe,
    id: "PRO-03"
  },
  {
    title: "Works and Cues Maintenance",
    Icon: Database,
    id: "PRO-04"
  }
];
---

<section class="bg-[#0C0C0C] text-[#F7F7F7] py-24 lg:py-40 overflow-hidden border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    
    <div class="flex justify-between items-end mb-16 lg:mb-24">
      <div class="flex flex-col gap-4">
        <SectionLabel>// System Capabilities</SectionLabel>
        <H2 class="text-4xl lg:text-5xl">
          Our <span class="italic text-white/30">Services</span>
        </H2>
      </div>
      
      <div class="hidden md:flex gap-1 h-8 items-end opacity-40" aria-hidden="true">
        {Array.from({ length: 12 }).map((_, i) => (
          <div 
            class="w-[2px] bg-[#A53029] animate-pulse" 
            style={`height: ${20 + Math.random() * 80}%; animation-delay: ${i * 0.1}s`}
          ></div>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-white/5 border border-white/5">
      {services.map((service) => {
        const { Icon } = service;
        return (
          <a href="/services" class="group relative bg-[#0C0C0C] p-8 lg:p-12 transition-all duration-500 hover:bg-[#161616]">
            <div class="absolute top-0 left-0 w-full h-0.5 bg-[#A53029] scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
            
            <div class="flex flex-col h-full justify-between gap-12">
              <div class="flex justify-between items-start">
                <span class="font-mono text-[9px] text-white/20 tracking-widest group-hover:text-[#A53029] transition-colors">
                  {service.id}
                </span>
                
                <div class="text-white/10 group-hover:text-[#A53029] transition-colors duration-500 transform group-hover:scale-110 group-hover:-rotate-6">
                  <Icon size={32} strokeWidth={1} />
                </div>
              </div>

              <h3 class="font-heading text-xl lg:text-2xl uppercase tracking-tight leading-tight group-hover:text-white transition-colors">
                {service.title}
              </h3>

              <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-all duration-500 translate-y-2 group-hover:translate-y-0">
                <span class="font-mono text-[8px] uppercase tracking-widest text-[#A53029]">View Specs</span>
                <div class="h-[1px] w-4 bg-[#A53029]"></div>
              </div>
            </div>
          </a>
        )
      })}
    </div>

    <div class="mt-12 flex justify-end">
        <p class="font-mono text-[9px] uppercase tracking-[0.3em] text-white/10 italic">
          High-Productivity Data Infrastructure // Ready for Transmission
        </p>
    </div>
  </div>
</section>

<style>
  @keyframes pulse {
    0%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(0.4); }
  }
  .animate-pulse {
    animation: pulse 1.5s infinite ease-in-out;
  }
</style>