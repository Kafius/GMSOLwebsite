---
import H2 from './headerfont/H2.astro';
import SectionLabel from './headerfont/SectionLabel.astro';
---

<section class="bg-[#FAF7F2] text-black py-0 overflow-hidden relative">
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" 
       style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 30px 30px;">
  </div>

  <div class="flex justify-center h-24 lg:h-32 relative z-10">
    <div class="w-[1px] h-full bg-gradient-to-b from-black/20 to-[#A53029]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-12 pb-24 lg:pb-40 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24 items-center">
      
      <div class="lg:col-span-5 order-2 lg:order-1">
        <div class="relative group">
          <div class="relative aspect-[4/5] overflow-hidden grayscale border border-black/5 group-hover:grayscale-0 transition-all duration-1000 shadow-2xl">
            <img
              src="https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?q=80&w=1200&auto=format&fit=crop"
              alt="Professional Studio Console"
              loading="lazy"
              decoding="async"
              width="1200"
              height="1500"
              class="w-full h-full object-cover scale-105 group-hover:scale-100 transition-transform duration-1000"
            />
          </div>
          
          <div class="absolute -bottom-4 -left-4 bg-black text-white px-4 py-2 font-mono text-[9px] uppercase tracking-widest shadow-lg">
             Ref: System_Backbone_01
          </div>
        </div>
      </div>

      <div class="lg:col-span-7 order-1 lg:order-2">
        <div class="flex flex-col gap-8">
          
          <div class="flex items-center gap-4">
            <SectionLabel>Track 01 // The Mission</SectionLabel>
          </div>

          <H2 class="leading-[0.9] text-black">
            Support for <br />
            <span class="text-transparent stroke-black italic">
              Performing Rights <br /> Organizations
            </span>
          </H2>

          <div class="max-w-xl mt-4">
            <p class="font-sans text-lg lg:text-xl text-gray-700 leading-relaxed">
              Our <strong class="text-black font-extrabold">MISSION</strong> at Global Music Solutions is to provide the highest level of service to support Performing Rights Organizations succeed in their responsibility to their members.
            </p>
            
            <p class="font-sans text-base text-gray-500 mt-6 leading-relaxed border-l-2 border-[#A53029]/20 pl-6">
              We empower societies so they can continue to be motivated in creating music for the world to enjoy, ensuring every cue and credit is harmonized with precision.
            </p>
          </div>

          <div class="mt-4">
            <a 
              href="/services" 
              class="group inline-flex items-center gap-8 border border-black/10 bg-gray-50 px-8 py-4 hover:border-black hover:bg-black transition-all duration-500"
            >
              <div class="flex flex-col">
                <span class="font-mono text-[9px] text-[#A53029] uppercase tracking-[0.3em] mb-1">Access Catalog</span>
                <span class="font-heading text-lg uppercase tracking-widest text-black group-hover:text-white transition-colors">
                  Learn More
                </span>
              </div>
              
              <div class="relative flex items-center justify-center w-10 h-10 rounded-full border border-black/10 group-hover:bg-[#A53029] group-hover:border-[#A53029] transition-all">
                 <svg 
                  xmlns="http://www.w3.org/2000/svg" 
                  width="18" height="18" 
                  viewBox="0 0 24 24" fill="none" 
                  stroke="currentColor" stroke-width="2" 
                  class="text-black group-hover:text-white group-hover:translate-x-1 transition-all"
                 >
                  <path d="M5 12h14m-7-7 7 7-7 7"/>
                 </svg>
              </div>
            </a>
          </div>

        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Outlined text effect for the light theme */
  .stroke-black {
    -webkit-text-stroke: 1px black;
  }
</style>