---
import H1 from '../headerfont/H1.astro';
import SectionLabel from '../headerfont/SectionLabel.astro';
---

<section class="relative bg-[#0a0a0a] py-28 lg:py-44 overflow-hidden border-b border-white/5">
  <div class="absolute inset-0 z-0 opacity-10">
    <div class="h-full w-full bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:40px_40px]"></div>
  </div>

  <div class="absolute right-0 top-0 h-full w-32 flex items-end gap-1 pb-10 opacity-30" aria-hidden="true">
      <div class="w-2 bg-[#A53029] h-[20%] animate-bounce"></div>
      <div class="w-2 bg-[#A53029] h-[60%] animate-bounce [animation-delay:0.2s]"></div>
      <div class="w-2 bg-[#A53029] h-[40%] animate-bounce [animation-delay:0.4s]"></div>
      <div class="w-2 bg-[#A53029] h-[80%] animate-bounce [animation-delay:0.1s]"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12">
    <div class="flex flex-col gap-6">
      
      <div class="flex items-center gap-4">
        <span class="px-2 py-1 border border-[#A53029] text-[#A53029] font-mono text-[10px] uppercase tracking-widest">
          High Fidelity
        </span>
        <SectionLabel>// Side B: Service Catalog</SectionLabel>
      </div>

      <H1 class="text-[12vw] lg:text-[6vw] leading-[0.85] text-white">
        Precision <br />
        <span class="text-transparent stroke-white italic">Processing</span>
      </H1>

      <div class="mt-8 max-w-xl">
        <p class="font-sans text-gray-400 text-lg lg:text-xl leading-relaxed border-l-2 border-[#A53029] pl-6">
          From automated cue sheet generation to rigorous quality assurance, we optimize the technical backbone of performing rights societies.
        </p>
      </div>

      <div class="mt-12 flex flex-wrap gap-12 border-t border-white/10 pt-8">
        <div>
            <p class="font-mono text-[9px] text-gray-500 uppercase tracking-widest">Efficiency Rate</p>
            <p class="text-white font-heading text-2xl uppercase italic">99.9%</p>
        </div>
        <div>
            <p class="font-mono text-[9px] text-gray-500 uppercase tracking-widest">Output Format</p>
            <p class="text-white font-heading text-2xl uppercase italic">Secure Cloud</p>
        </div>
        <div>
            <p class="font-mono text-[9px] text-gray-500 uppercase tracking-widest">Service Type</p>
            <p class="text-white font-heading text-2xl uppercase italic">Bespoke</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .stroke-white {
    -webkit-text-stroke: 1.5px white;
  }

  @keyframes bounce {
    0%, 100% { transform: scaleY(1); transform-origin: bottom; }
    50% { transform: scaleY(1.5); transform-origin: bottom; }
  }

  .animate-bounce {
    animation: bounce 1.5s infinite ease-in-out;
  }
</style>