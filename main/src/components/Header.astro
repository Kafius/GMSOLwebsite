---
// Header.astro
---

<nav aria-label="Main navigation" class="fixed top-0 left-0 w-full z-[100] transition-all duration-300 border-b border-white/5 bg-[#0C0C0C]/90 backdrop-blur-md">
  <div class="flex justify-between items-center px-10 lg:px-24 h-24 max-sm:px-6 max-sm:h-20 max-w-7xl mx-auto w-full">
    
    <a href="/" class="flex items-center z-[110]">
      <img
        src="/images/logos/GMS_LOGOx1.svg"
        alt="GMS Logo"
        class="w-[180px] lg:w-[220px] h-auto object-contain brightness-0 invert"
      />
    </a>

    <div class="hidden md:flex items-center gap-12">
      <ul class="flex gap-10 text-[11px] uppercase tracking-[0.3em] font-bold text-[#F7F7F7]/60">
        <li class="hover:text-[#A53029] hover:tracking-[0.4em] transition-all duration-300">
          <a href="/about">About Us</a>
        </li>
        <li class="hover:text-[#A53029] hover:tracking-[0.4em] transition-all duration-300">
          <a href="/services">Services</a>
        </li>
        <li class="hover:text-[#A53029] hover:tracking-[0.4em] transition-all duration-300">
          <a href="/blog">Blog</a>
        </li>
      </ul>

      <a
        href="/contact"
        aria-label="Contact Us"
        class="group relative px-6 py-3 bg-[#A53029] text-white text-[10px] uppercase tracking-widest overflow-hidden transition-all hover:pr-10 hover:bg-[#8B2420]"
      >
        <span class="relative z-10">Contact Us</span>
        <span class="absolute right-2 opacity-0 group-hover:opacity-100 transition-all duration-300">→</span>
      </a>
    </div>

    <button id="menu-btn" class="md:hidden flex flex-col gap-2 z-[110] relative focus:outline-none" aria-label="Toggle Menu">
      <div id="line-1" class="w-6 h-[2px] bg-[#F7F7F7] transition-all duration-300 origin-center"></div>
      <div id="line-2" class="w-6 h-[2px] bg-[#F7F7F7] transition-all duration-300 origin-center"></div>
    </button>

  </div>

  <div id="mobile-menu" class="fixed inset-0 bg-[#0C0C0C] translate-y-[-100%] transition-transform duration-500 ease-in-out md:hidden flex flex-col items-center justify-center">
    <ul class="flex flex-col items-center gap-10 text-[14px] uppercase tracking-[0.4em] font-bold text-[#F7F7F7]">
      <li><a href="/about" class="mobile-link">About Us</a></li>
      <li><a href="/services" class="mobile-link">Services</a></li>
      <li><a href="/blog" class="mobile-link">Blog</a></li>
      <li>
        <a href="/contact" class="mobile-link px-8 py-4 border border-[#A53029] text-[#A53029] mt-4">Contact Us</a>
      </li>
    </ul>
  </div>
</nav>

<div class="h-24 max-sm:h-20"></div>

<style>
  /* Logic for the "X" animation */
  .menu-open #line-1 {
    transform: translateY(5px) rotate(45deg);
  }
  .menu-open #line-2 {
    transform: translateY(-5px) rotate(-45deg);
  }

  /* Logic for the Menu Slide Down */
  .menu-open #mobile-menu {
    transform: translateY(0);
  }

  a.active {
    color: #F7F7F7;
    border-bottom: 2px solid #A53029;
    padding-bottom: 4px;
  }
</style>

<script>
  function setupMenu() {
    const menuBtn = document.getElementById('menu-btn');
    const nav = document.querySelector('nav');
    const mobileLinks = document.querySelectorAll('.mobile-link');

    const toggleMenu = () => {
      nav?.classList.toggle('menu-open');
      document.body.classList.toggle('overflow-hidden');
    };

    menuBtn?.addEventListener('click', toggleMenu);

    // Close menu when a link is clicked
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        nav?.classList.remove('menu-open');
        document.body.classList.remove('overflow-hidden');
      });
    });
  }

  // Runs on initial load
  setupMenu();

  // Runs when navigating between pages (if using Astro View Transitions)
  document.addEventListener('astro:after-swap', setupMenu);
</script>