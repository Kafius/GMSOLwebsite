---
const navItems = [
  { name: 'About Us', href: '/about' },
  { name: 'Services', href: '/services' },
  { name: 'Blog', href: '/blog' },
];
---

<header class="fixed top-0 left-0 w-full z-100 border-b border-white/5 bg-[#0C0C0C]/90 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-6 lg:px-24 h-20 lg:h-24 flex items-center justify-between">

    <a href="/" aria-label="GMS Home">
      <img
        src="/images/logos/GMS_LOGOx1.svg"
        alt="GMS Logo"
        class="w-[180px] lg:w-[220px] h-auto object-contain brightness-0 invert"
      />
    </a>

    <nav class="hidden md:flex items-center gap-12">
      <ul class="flex gap-10 text-[11px] uppercase tracking-[0.3em] font-bold text-[#F7F7F7]/60">
        {navItems.map(item => (
          <li class="hover:text-[#A53029] hover:tracking-[0.4em] transition-all duration-300">
            <a href={item.href}>{item.name}</a>
          </li>
        ))}
      </ul>
      <a
        href="/contact"
        class="group relative px-6 py-3 bg-[#A53029] text-white text-[10px] uppercase tracking-widest overflow-hidden transition-all hover:pr-10 hover:bg-[#8B2420]"
      >
        <span class="relative z-10">Contact Us</span>
        <span class="absolute right-2 opacity-0 group-hover:opacity-100 transition-all duration-300">→</span>
      </a>
    </nav>

    <button
      id="mobile-menu-toggle"
      class="md:hidden flex flex-col gap-[6px] p-2 focus:outline-none"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span id="line-1" class="block w-6 h-[2px] bg-[#F7F7F7] transition-all duration-300 origin-center"></span>
      <span id="line-2" class="block w-6 h-[2px] bg-[#F7F7F7] transition-all duration-300 origin-center"></span>
    </button>

  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden border-t border-white/10 bg-[#0C0C0C] px-6 py-8 flex-col items-center gap-8"
    aria-label="Mobile navigation"
  >
    {navItems.map(item => (
      <a href={item.href} class="text-[13px] uppercase tracking-[0.4em] font-bold text-[#F7F7F7] mobile-link">
        {item.name}
      </a>
    ))}
    <a
      href="/contact"
      class="mobile-link px-8 py-4 border border-[#A53029] text-[#A53029] text-[12px] uppercase tracking-widest font-bold"
    >
      Contact Us
    </a>
  </nav>
</header>

<div class="h-20 lg:h-24"></div>

<script is:inline>
  var toggle = document.getElementById('mobile-menu-toggle');
  var menu = document.getElementById('mobile-menu');
  var line1 = document.getElementById('line-1');
  var line2 = document.getElementById('line-2');

  function openMenu() {
    menu.classList.remove('hidden');
    menu.classList.add('flex');
    toggle.setAttribute('aria-expanded', 'true');
    line1.style.transform = 'translateY(4px) rotate(45deg)';
    line2.style.transform = 'translateY(-4px) rotate(-45deg)';
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    menu.classList.add('hidden');
    menu.classList.remove('flex');
    toggle.setAttribute('aria-expanded', 'false');
    line1.style.transform = '';
    line2.style.transform = '';
    document.body.style.overflow = '';
  }

  if (toggle && menu) {
    toggle.addEventListener('click', function () {
      var isOpen = !menu.classList.contains('hidden');
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    document.querySelectorAll('.mobile-link').forEach(function (link) {
      link.addEventListener('click', closeMenu);
    });
  }
</script>
