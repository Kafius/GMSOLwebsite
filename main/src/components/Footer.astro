---
---
<footer class="bg-[#0C0C0C] text-[#F7F7F7] pt-24 pb-12 overflow-hidden border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 lg:px-12">
    
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 mb-24">
      
      <div class="lg:col-span-4">
        <div class="flex items-center gap-4 mb-8">
          <a href="/" class="block">
            <img
              src="/images/logos/GMS_ICONx1.svg"
              alt="gms logo"
              class="w-auto h-10 object-contain brightness-0 invert" 
            />
          </a>
          <div class="h-8 w-[1px] bg-white/20 hidden md:block"></div> 
          <span class="font-heading text-2xl tracking-tighter uppercase leading-none text-[#F7F7F7]">
            Global Music <br/> <span class="text-[#A53029]">Solutions</span>
          </span>
        </div>
        <p class="font-sans text-[#F7F7F7]/50 text-sm leading-relaxed max-w-xs">
          Providing technical precision in royalty administration, cue sheet management, and global backend solutions.
        </p>
      </div>

      <div class="lg:col-span-2 lg:col-start-6">
        <span class="font-mono text-[10px] uppercase tracking-[0.4em] text-[#F7F7F7]/30 block mb-8">// Navigation</span>
        <ul class="space-y-4 font-heading text-lg uppercase tracking-tight">
          <li><a href="/" class="hover:text-[#A53029] transition-colors">Home</a></li>
          <li><a href="/services" class="hover:text-[#A53029] transition-colors">Services</a></li>
          <li><a href="/blog" class="hover:text-[#A53029] transition-colors">Blog</a></li>
          <li><a href="/contact" class="hover:text-[#A53029] transition-colors">Contact</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <span class="font-mono text-[10px] uppercase tracking-[0.4em] text-[#F7F7F7]/30 block mb-8">// Information</span>
        <ul class="space-y-4 font-mono text-[11px] uppercase tracking-widest text-[#F7F7F7]/60">
          <li><a href="/privacy" class="hover:text-[#F7F7F7] transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="hover:text-[#F7F7F7] transition-colors">Terms of Service</a></li>
          <li><a href="/cookies" class="hover:text-[#F7F7F7] transition-colors">Cookie Policy</a></li>
        </ul>
      </div>

      <div class="lg:col-span-3">
        <span class="font-mono text-[10px] uppercase tracking-[0.4em] text-[#F7F7F7]/30 block mb-8">// Terminal_Access</span>
        <p class="font-sans text-sm mb-2 text-[#F7F7F7]/80">info@globalmusicsolutions.com</p>
        <p class="font-sans text-sm text-[#F7F7F7]/40 italic uppercase tracking-wider">Global Distribution Centers: <br/> YYZ</p>
      </div>
    </div>

    <div class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8">
      
      <div class="flex items-center gap-6">
        <span class="font-mono text-[9px] uppercase tracking-[0.5em] text-[#F7F7F7]/20">
          © 2026 GLOBAL MUSIC SOLUTIONS. ALL RIGHTS RESERVED.
        </span>
        <div class="hidden md:flex gap-1 h-3 items-end opacity-40" aria-hidden="true">
           <div class="w-[2px] h-full bg-[#A53029] animate-pulse"></div>
           <div class="w-[2px] h-[60%] bg-[#A53029] animate-pulse" style="animation-delay: 0.2s"></div>
           <div class="w-[2px] h-[80%] bg-[#A53029] animate-pulse" style="animation-delay: 0.4s"></div>
        </div>
      </div>

      <button
        onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
        aria-label="Return to top of page"
        class="font-mono text-[9px] uppercase tracking-widest border border-white/10 px-4 py-2 hover:bg-[#F7F7F7] hover:text-[#0C0C0C] transition-all"
      >
        [ Return_to_Top ]
      </button>

    </div>
  </div>
</footer>